{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src/index.html",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "EZCut",
    "version": "0.0.23"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true
      },
      "path": {
        "all": true
      },
      "fs": {
        "all": true
      },
      "shell": {
        "all": true,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.kaiyuan.ezcut",
      "icon": [
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "windows": {
        "digestAlgorithm": "sha256"
      },
      "macOS": {
        "minimumSystemVersion": "10.15"
      }
    },
    "windows": [
      {
        "title": "EZCut",
        "width": 724,
        "height": 750,
        "minWidth": 640,
        "minHeight": 430,
        "resizable": true,
        "visible": true
      }
    ]
  }
}